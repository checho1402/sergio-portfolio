---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { 
      slug: project.slug
    },
    props: project,
  }));
}



const project = Astro.props;
const { Content } = await project.render();

const lang = project.data.lang || 'en';
const allProjects = await getCollection('projects');

const alternateProject = allProjects.find(
  (p) =>
    p.data.group === project.data.group &&
    p.data.lang !== project.data.lang
);


const translations = {
  return: { 
    en: "Content", 
    es: "Contenido" 
  },
  published: { 
    en: "Published in", 
    es: "Publicado en" 
  },
  lecture: { 
    en: "Lecture time", 
    es: "Tiempo de lectura" 
  },
  minutes: { 
    en: "minutes", 
    es: "minutos" 
  },
  repository: {
    en: "✨ Repository Link",
    es: "✨ Link al Repositorio"
  }
}



---

<Layout title={`${project.data.title} | Sergio Ramos`}>
  <Header />

  <main class="min-h-screen px-4 sm:px-6 md:px-6">
    <article class="max-w-3xl mx-auto pt-24 sm:pt-32 md:pt-48 pb-24 space-y-8">

      <a href="/projects" class="group text-secondary hover:text-black dark:hover:text-white text-gray-500 dark:text-gray-400 relative flex w-fit flex-nowrap items-center gap-2 rounded text-sm transition-colors duration-300 ease-in-out lg:text-base">
        <div class="bg-tertiary/50 bg-gray-200 dark:bg-gray-900 group-hover:bg-gray-300 dark:group-hover:bg-gray-800 rounded-md p-4">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="absolute top-1/2 left-2 size-4 -translate-y-1/2 fill-none stroke-current stroke-2 lg:size-5"
          >
            <line
              x1="0"
              y1="12"
              x2="19"
              y2="12"
              class="translate-x-1 scale-x-0 transition-transform duration-300 ease-in-out group-hover:translate-x-0 group-hover:scale-x-80"
            ></line>
            <polyline
              points="12 5 5 12 12 19"
              class="translate-x-1 transition-transform duration-300 ease-in-out group-hover:-translate-x-1 lg:translate-x-0"
            ></polyline>
          </svg>
        </div>
        
        <h1 data-en={translations.return.en} data-es={translations.return.es}>
          {translations.return.en}
        </h1>
      </a>

      <header class="space-y-8">
        <img src={project.data.cover} alt={project.data.title} class="w-full rounded-3xl object-cover aspect-video"/>
            
        <div class="flex flex-col gap-8 sm:flex-row sm:items-start">
          
          <div class="sm:basis-[80%] space-y-4">
            <h1 class="text-3xl sm:text-4xl md:text-4xl font-bold text-black dark:text-white max-w-2xl">
              {project.data.title}
            </h1>

            {project.data.description && (
              <p class="text-m text-secondary max-w-xl text-gray-700 dark:text-gray-300">
                {project.data.description}
              </p>
            )}
          </div>


        </div>
      
        <!-- acciones -->
        <div class="flex flex-wrap gap-3 pt-2">
          <a 
            href={project.data.url} 
            class="ai-neon-effect px-4 py-2 rounded-lg dark:bg-white/10 bg-gray-100 dark:text-white text-gray-600 font-semibold backdrop-blur hover:dark:bg-white/20 hover:bg-gray-200 transition inline-block"
            data-en={translations.repository.en} data-es={translations.repository.es}
          >
            ✨ Link al Repositorio
          </a>
      
          <a href="https://github.com/checho1402"
							   class="flex items-center gap-2 px-4 py-2 rounded-lg dark:bg-white/5 bg-gray-50 dark:text-white/80 text-gray-600 hover:dark:bg-white/10 hover:bg-gray-100 transition">
                <img src="https://cdn.simpleicons.org/github"
                  class="w-4 h-4 dark:invert" /> Checho_1402
              
					</a>

        </div>
      
      </header>
      
      

      <section class="content">
        <Content />
      </section>

    </article>
  </main>

  <Footer />
  
  <script
    define:vars={{
      alternateSlug: alternateProject?.slug ?? null,
      currentPostLang: lang
    }}
  >
    if (alternateSlug) {
      const observer = new MutationObserver(() => {
        const currentLang =
          document.documentElement.getAttribute('data-lang');

        if (currentLang && currentLang !== currentPostLang) {
          window.location.href = `/projects/${alternateSlug}`;
        }
      });

      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-lang'],
      });
    }
  </script>
  
</Layout>
