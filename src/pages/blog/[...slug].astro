---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { 
      slug: post.slug
    },
    props: post,
  }));
}



const post = Astro.props;
const { Content } = await post.render();

const lang = post.data.lang || 'en';
const allPosts = await getCollection('blog');

const alternatePost = allPosts.find(
  (p) =>
    p.data.group === post.data.group &&
    p.data.lang !== post.data.lang
);


const translations = {
  return: { 
    en: "Content", 
    es: "Contenido" 
  },
  published: { 
    en: "Published in", 
    es: "Publicado en" 
  },
  lecture: { 
    en: "Lecture time", 
    es: "Tiempo de lectura" 
  },
  minutes: { 
    en: "minutes", 
    es: "minutos" 
  }
}



---

<Layout title={`${post.data.title} | Sergio Ramos`}>
  <Header />

  <main class="min-h-screen px-4 sm:px-6 md:px-6">
    <article class="max-w-3xl mx-auto pt-24 sm:pt-32 md:pt-48 pb-24 space-y-8">

      <a href="/blog" class="group text-secondary hover:text-black dark:hover:text-white text-gray-500 dark:text-gray-400 relative flex w-fit flex-nowrap items-center gap-2 rounded text-sm transition-colors duration-300 ease-in-out lg:text-base">
        <div class="bg-tertiary/50 bg-gray-200 dark:bg-gray-900 group-hover:bg-gray-300 dark:group-hover:bg-gray-800 rounded-md p-4">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="absolute top-1/2 left-2 size-4 -translate-y-1/2 fill-none stroke-current stroke-2 lg:size-5"
          >
            <line
              x1="0"
              y1="12"
              x2="19"
              y2="12"
              class="translate-x-1 scale-x-0 transition-transform duration-300 ease-in-out group-hover:translate-x-0 group-hover:scale-x-80"
            ></line>
            <polyline
              points="12 5 5 12 12 19"
              class="translate-x-1 transition-transform duration-300 ease-in-out group-hover:-translate-x-1 lg:translate-x-0"
            ></polyline>
          </svg>
        </div>
        
        <h1 data-en={translations.return.en} data-es={translations.return.es}>
          {translations.return.en}
        </h1>
      </a>

      <header class="space-y-8">
        <img src={post.data.cover} alt={post.data.title} class="w-full rounded-3xl object-cover aspect-video"/>
            
        <div class="flex flex-col gap-8 sm:flex-row sm:items-start">
          
          <div class="sm:basis-[80%] space-y-4">
            <h1 class="text-3xl sm:text-4xl md:text-4xl font-bold text-black dark:text-white max-w-2xl">
              {post.data.title}
            </h1>

            {post.data.description && (
              <p class="text-m text-secondary max-w-xl text-gray-700 dark:text-gray-300 md:pr-60">
                {post.data.description}
              </p>
            )}
          </div>


          <div class="sm:basis-[20%] flex-col gap-8 text-sm text-secondary justify-start sm:justify-end">
            <div class="flex flex-col text-left">
              <span class="mb-1 text-gray-500 dark:text-gray-400" data-en={translations.published.en} data-es={translations.published.es}>{translations.published.en}</span>
              <span class="text-black dark:text-white font-semibold">{post.data.date}</span>
            </div>

            <div class="flex flex-col text-left pt-6">
              <span class="mb-1 text-gray-500 dark:text-gray-400" data-en={translations.lecture.en} data-es={translations.lecture.es}>{translations.lecture.en}</span>
              <span class="text-black dark:text-white font-semibold" data-en={`${post.data.readingTime} ${translations.minutes.en}`} data-es={`${post.data.readingTime} ${translations.minutes.es}`}></span>
            </div>
          </div>

        </div>
    
      
      </header>
      
      

      <section class="content">
        <Content />
      </section>

    </article>
  </main>

  <Footer />
  
  <script
    define:vars={{
      alternateSlug: alternatePost?.slug ?? null,
      currentPostLang: lang
    }}
  >
    if (alternateSlug) {
      const observer = new MutationObserver(() => {
        const currentLang =
          document.documentElement.getAttribute('data-lang');

        if (currentLang && currentLang !== currentPostLang) {
          window.location.href = `/blog/${alternateSlug}`;
        }
      });

      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-lang'],
      });
    }
  </script>
  
</Layout>
