---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import heroPhoto from '../assets/foto.jpg';
import linkedIn from '../assets/linkedin.png';
import contact from '../assets/contact.png';

const translations = {
  greeting: { 
    en: "$ whoami", 
    es: "$ whoami" 
  },
  name: { 
    en: "Sergio Ramos", 
    es: "Sergio Ramos" 
  },
  description: { 
    en: "Technologist in Information Systems and Full Stack Developer with more than 2 years of experience, specialized in creating modern, scalable and user-centered solutions.", 
    es: "Tecnólogo en Sistemas de información y Desarrollador Full Stack con más de 2 años de experiencia, especializado en crear soluciones modernas, escalables y centradas en el usuario." 
  },  
  resume: { 
    en: "Tip: Press Ctrl + P to print my formal resume.", 
    es: "Tip: Presiona Ctrl + P para imprimir mi currículum formal." 
  },
  availability: {
    en: "Open to work",
    es: "Disponible para trabajar"
  },
  viewProjects: { 
    en: "cd ~/Projects", 
    es: "cd ~/Proyectos" 
  },
  getInTouch: { 
    en: "$ contact --me", 
    es: "$ contactame" 
  },
  about: { 
    en: "$echo 'About Me'", 
    es: "$echo 'Sobre mí'" 
  },
  aboutDesc: {
    es: "Soy Desarrollador Full Stack con experiencia en la creación de aplicaciones web completas, desde el diseño de la arquitectura hasta la implementación y despliegue. Trabajo integrando APIs, bases de datos y servicios modernos, con foco en rendimiento, mantenibilidad y experiencia de usuario. Me adapto bien a equipos colaborativos, sigo buenas prácticas de desarrollo y busco entregar soluciones estables que aporten valor real al negocio. Estoy interesado en oportunidades remotas o híbridas donde pueda seguir creciendo profesionalmente y contribuir a proyectos bien estructurados.",
    en: "I am a Full Stack Developer with experience building end-to-end web applications, from architecture design to implementation and deployment. I work integrating APIs, databases, and modern services, with a focus on performance, maintainability, and user experience. I adapt well to collaborative teams, follow development best practices, and aim to deliver stable solutions that bring real business value. I am interested in remote or hybrid opportunities where I can continue growing professionally and contribute to well-structured projects."
  },
  tech: { 
    en: "$ls ~/tools", 
    es: "$ls ~/tecnologías" 
  }
};

---

<Layout title={`Index | Sergio Ramos`}>
	<Header />
	
	<main class="min-h-screen px-4 sm:px-6 md:px-6">
		<section class="max-w-3xl mx-auto min-h-[calc(100vh-5rem)] flex flex-col justify-center pt-30 sm:pt-30 pb-16 sm:pb-24 fade-in">
			<div class="flex flex-col items-center gap-2 sm:gap-2">
				<div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
					<div class="w-48 h-48 sm:w-36 sm:h-36 md:w-48 md:h-48 rounded-full bg-gray-100 dark:bg-gray-800 border-1 border-gray-300 dark:border-gray-600 flex items-center justify-center overflow-hidden animated-border always-visible flex-shrink-0 shadow-lg dark:shadow-white/20">
						<img src={heroPhoto.src} alt="Sergio Ramos" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
						<span class="text-2xl sm:text-3xl md:text-4xl text-gray-500 dark:text-gray-400 hidden">📷</span>
					</div>
					<div class="flex flex-col items-center gap-2">
						<div class="animated-border-general always-visible px-3 sm:px-4 py-2 rounded-full border border-gray-300 dark:border-gray-600 h-fit">
							<p class="text-xs sm:text-sm font-medium text-gray-900 dark:text-white whitespace-nowrap" data-en={translations.availability.en} data-es={translations.availability.es}>{translations.availability.en}</p>
						</div>
						<div class="flex gap-3 mt-2 text-gray-600 dark:text-gray-400">

							<!-- GitHub -->
							<a href="https://github.com/checho1402" target="_blank"
							   class="group relative transition hover:text-gray-900 dark:hover:text-white">
							  <img src="https://cdn.simpleicons.org/github"
								   class="w-4 h-4 dark:invert" />
							  <span class="tooltip dark:invert">&gt; github</span>
							</a>
						  
							<!-- LinkedIn (nombre correcto del icono) -->
							<a href="https://www.linkedin.com/in/sergio-leandro-ramos-villena-45b0bb270/" target="_blank"
							   class="group relative transition hover:text-gray-900 dark:hover:text-white">
							  <img src={linkedIn.src}
								   class="w-4 h-4" />
							  <span class="tooltip dark:invert">&gt; linkedin</span>
							</a>
						  
							<!-- Google Scholar -->
							<a href="https://scholar.google.com/citations?user=1iFjGNsAAAAJ&hl" target="_blank"
							   class="group relative transition hover:text-gray-900 dark:hover:text-white">
							  <img src="https://cdn.simpleicons.org/googlescholar"
								   class="w-4 h-4" />
							  <span class="tooltip dark:invert">&gt; scholar</span>
							</a>
						  
							<!-- ORCID -->
							<a href="https://orcid.org/0009-0006-2861-9296" target="_blank"
							   class="group relative transition hover:text-gray-900 dark:hover:text-white">
							  <img src="https://cdn.simpleicons.org/orcid"
								   class="w-4 h-4" />
							  <span class="tooltip dark:invert">&gt; orcid</span>
							</a>
						  
							<!-- Scopus -->
							<a href="https://www.scopus.com/authid/detail.uri?authorId=59917444800" target="_blank"
							   class="group relative transition hover:text-gray-900 dark:hover:text-white">
							  <img src="https://cdn.simpleicons.org/scopus"
								   class="w-4 h-4" />
							  <span class="tooltip dark:invert">&gt; scopus</span>
							</a>
						  
							<!-- Email -->
							<a href="https://mail.google.com/mail/?view=cm&fs=1&to=slrv.ramosv@gmail.com&su=Contacto%20Portafolio&body=Hola%20Sergio,"
							   class="group relative transition hover:text-gray-900 dark:hover:text-white">
							  <img src="https://cdn.simpleicons.org/gmail"
								   class="w-4 h-4 dark:invert" />
							  <span class="tooltip dark:invert">&gt; email</span>
							</a>
						  
							<!-- Add Contact (icono válido) -->
							<a href="/contact.vcf"  download
							   class="group relative transition hover:text-gray-900 dark:hover:text-white">
							  <img src={contact.src}
								   class="w-4 h-4 dark:invert" />
							  <span class="tooltip dark:invert">&gt; vcard</span>
							</a>
						  
						  </div>
						  
						
					</div>

				</div>
				<div>
					<p class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-400 mb-2" data-en={translations.greeting.en} data-es={translations.greeting.es}>{translations.greeting.en}</p>
					<h1 class="name-cursor text-4xl sm:text-5xl md:text-6xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6 px-2 sm:px-0" data-en={translations.name.en} data-es={translations.name.es}>
						{translations.name.en}
					</h1>
					<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 max-w-lg mx-auto mb-4 sm:mb-6 px-2 sm:px-0" data-en="Technologist in Information Systems and Full Stack Developer with more than 2 years of experience, specialized in creating modern, scalable and user-centered solutions." data-es="Tecnólogo en Sistemas de información y Desarrollador Full Stack con más de 2 años de experiencia, especializado en crear soluciones modernas, escalables y centradas en el usuario.">
						<span class="font-semibold text-gray-900 dark:text-white">Technologist in Information Systems</span> and <span class="font-semibold text-gray-900 dark:text-white">Full Stack Developer</span> with more than 2 years of experience, specialized in creating modern, scalable and user-centered solutions.
					</p>
					<p id="print-tip" class="print-tip mt-6 text-s text-gray-500 dark:text-gray-400 text-center" data-en="Tip: Press Ctrl + P to print my formal resume." data-es="Tip: Presiona Ctrl + P para imprimir mi currículum formal.">
						Tip: Press <span class="font-semibold text-gray-900 dark:text-white">Ctrl</span> +<span class="font-semibold text-gray-900 dark:text-white"> P </span>to print my formal resume.
					</p>
					<div class="flex mt-6 flex-wrap gap-2 sm:gap-3 justify-center px-2 sm:px-0">
						<a href="/projects" class="cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-medium rounded-full hover:animated-bg transition-all" data-en={translations.viewProjects.en} data-es={translations.viewProjects.es}>
							{translations.viewProjects.en}
						</a>
						<a href="/contact" class="animated-border cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white font-medium rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" data-en={translations.getInTouch.en} data-es={translations.getInTouch.es}>
							{translations.getInTouch.en}
						</a>
					</div>
				</div>
			</div>
		</section>

		<section class="max-w-3xl mx-auto py-12 sm:py-16 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">
			<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8" data-en={translations.about.en} data-es={translations.about.es}>{translations.about.en}</h2>
			<div class="space-y-3 sm:space-y-4 text-base sm:text-lg leading-relaxed text-gray-600 dark:text-gray-400" data-en={translations.aboutDesc.en} data-es={translations.aboutDesc.es}>
				{translations.aboutDesc.en}
			</div>
		</section>

		<section class="max-w-3xl mx-auto py-12 sm:py-16 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">
			<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8" data-en={translations.tech.en} data-es={translations.tech.es}>{translations.tech.en}</h2>
			
			<div class="tech-ticker-container">
				<div class="tech-ticker-content">
					<!-- First set -->
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">JavaScript</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">TypeScript</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">React</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Next.js</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Astro</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Tailwind CSS</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Node.js</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">PostgreSQL</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">MongoDB</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Docker</p>
					</div>
					
					<!-- Second set for seamless looping -->
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">JavaScript</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">TypeScript</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">React</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Next.js</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Astro</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Tailwind CSS</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Node.js</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">PostgreSQL</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">MongoDB</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Docker</p>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const observerOptions = {
				root: null,
				rootMargin: '0px',
				threshold: 0.1
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
					}
				});
			}, observerOptions);

			document.querySelectorAll('.fade-in').forEach(el => {
				observer.observe(el);
			});

			window.addEventListener('scroll', () => {
				const scrolled = window.pageYOffset;
				document.querySelectorAll('.parallax-section').forEach(section => {
					const speed = 0.1;
					(section as HTMLElement).style.transform = `translateY(${scrolled * speed}px)`;
				});
			});
		});
		
		document.addEventListener("keydown", (e) => {
			const isCtrlP =
				(e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "p";

			if (!isCtrlP) return;
			e.preventDefault();

			const lang = document.documentElement.getAttribute("data-lang") || "en";

			const pdfUrl =
				lang === "es"
				? "/resume-es.pdf"
				: "/resume-en.pdf";

			let iframe = document.getElementById("resume-print-frame");

			if (!iframe) {
				iframe = document.createElement("iframe");
				iframe.id = "resume-print-frame";
				iframe.style.position = "fixed";
				iframe.style.width = "0";
				iframe.style.height = "0";
				iframe.style.border = "0";
				document.body.appendChild(iframe);
			}

			iframe.src = pdfUrl;

			iframe.onload = () => {
				iframe.contentWindow.focus();
				iframe.contentWindow.print();
			};
		});
	</script>

	  
</Layout>
